let mapleader=" "

set hlsearch
set ignorecase
set incsearch
set smartcase
set scrolloff=5

set number
set relativenumber
set backspace=indent,eol,start

noremap <C-S-A-a> <C-a>
" noremap <C-S-A-b> <C-b>
" noremap <C-S-A-c> <C-c>
nnoremap <C-S-A-d> <C-d>zz
noremap <C-S-A-e> <C-e>
" noremap <C-S-A-f> <C-f>
noremap <C-S-A-g> <C-g>
" noremap <C-S-A-h> <C-h>
nnoremap <C-S-A-i> :vsc View.NavigateForward<CR>
" noremap <C-S-A-j> <C-j>
nnoremap <C-S-A-k> :vsc Edit.ParameterInfo<CR>
" noremap <C-S-A-l> <C-l>
" noremap <C-S-A-m> <C-m>
" noremap <C-S-A-n> <C-n>
nnoremap <C-S-A-o> :vsc View.NavigateBackward<CR>
" noremap <C-S-A-p> <C-p>
" noremap <C-S-A-q> <C-q>
noremap <C-S-A-r> <C-r>
" noremap <C-S-A-s> <C-s>
noremap <C-S-A-t> <C-t>
nnoremap <C-S-A-u> <C-u>zz
noremap <C-S-A-v> <C-v>
noremap <C-S-A-w> <C-w>
noremap <C-S-A-x> <C-x>
noremap <C-S-A-y> <C-y>
" noremap <C-S-A-z> <C-z>
" noremap <C-S-A-[> <C-[>
noremap <C-S-A-]> <C-]>
noremap <C-S-A-6> <C-6>

" noremap <C-S-A-[> <Esc>
inoremap <C-S-A-a> <C-o>0
" inoremap <C-S-A-a> <Home> " not working
inoremap <C-S-A-e> <End>
" inoremap <C-S-A-b> <Left>
" inoremap <C-S-A-f> <Right>
inoremap <C-S-A-d> <Del>
" inoremap <C-S-A-h> <BS>
" inoremap <C-S-A-j> <CR>
inoremap <C-S-A-y> <C-y>
inoremap <C-S-A-w> <C-w>
" inoremap <C-S-A-u> <C-u> " not working
inoremap <C-S-A-u> <C-o>d^

xnoremap gc :vsc Edit.CommentSelection<cr>
nnoremap gcc V:vsc Edit.CommentSelection<cr>
nnoremap gD :vsc Edit.GoToDeclaration<CR>
nnoremap gd :vsc Edit.GoToDefinition<CR>
nnoremap <C-]> :vsc Edit.GoToDefinition<CR>
nnoremap gI :vsc Edit.GoToImplementation<CR>
nnoremap gr :vsc Edit.FindAllReferences<CR>
nnoremap K :vsc Edit.QuickInfo<CR>
inoremap <C-S-A-k> <C-o>:vsc Edit.ParameterInfo<CR>

nnoremap cr :vsc Refactor.Rename<CR>
nnoremap ca :vsc EditorContextMenus.CodeWindow.QuickActionsForPosition<CR>

nnoremap <leader>m :vsc Edit.FormatDocument<CR>

" CTRL+P で Edit.GoToAll で全検索であるため限定したコマンドを定義
nnoremap <leader>ff :vsc Edit.GoToFile<CR>
nnoremap <leader>fw :vsc Edit.GoToText<CR>
nnoremap <leader>fo :vsc Edit.GoToRecentFile<CR>
nnoremap <leader><leader> :vsc Edit.GoToRecentFile<CR>
nnoremap <leader>fs :vsc Edit.GoToSymbol<CR>

" git
nnoremap <leader>gb :vsc Team.Git.Annotate<CR>

nnoremap [d :vsc View.PreviousError<CR>
nnoremap ]d :vsc View.NextError<CR>

" paste from 0 register
nnoremap <leader>p "0p
xnoremap <leader>p "0p
nnoremap <leader>P "0P
xnoremap <leader>P "0P

" TODO: 消す https://github.com/VsVim/VsVim/pull/3095
xnoremap P "_dP

" &でフラグを維持するように変更 (Neovimと同じ)
nnoremap & :&&<CR>
xnoremap & :&&<CR>

" ESC x 2でハイライトリセット
nnoremap <ESC><ESC> :nohlsearch<CR>

" visual starが動かないのでxnoremapは使えない
" xnoremap gs *Ncgn
nnoremap gs *Ncgn
